# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key
DJANGO_DEBUG=False

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=iotplatform
POSTGRES_USER=iotuser
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://iotuser:change-me-strong-password@postgres:5432/iotplatform

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MQTT Broker ─────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=False

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80

# ─── Security (production) ───────────────────────────────────────────────────
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
